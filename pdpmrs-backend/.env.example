# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000

# --- Database (CON-002, CON-011) ---
DATABASE_URL=postgresql://pdpmrs:pdpmrs@postgres:5432/pdpmrs

# --- Cache (CON-003, CON-014) ---
REDIS_URL=redis://redis:6379
REDIS_TTL_SECONDS=3600

# --- Auth (CON-018) ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- File storage (CON-012, CON-013) ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# --- Reservation lifecycle ---
RESERVATION_EXPIRY_HOURS=48
RESERVATION_EXPIRATION_CRON=*/10 * * * *

# --- Email / Notification domain ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=no-reply@pdpmrs.local

# --- AI Assistance Layer (CON-005, CON-006, CON-007, CON-010) ---
OCR_SERVICE_URL=http://paddleocr:8866/ocr
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b-instruct
TRANSLATION_SERVICE_URL=http://nllb:8010/translate
AI_REQUEST_TIMEOUT_MS=30000

# --- External integrations (CON-020) ---
MEDICINE_PROVIDER_BASE_URL=
MEDICINE_PROVIDER_API_KEY=
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_API_KEY=
