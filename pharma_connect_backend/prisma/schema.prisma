// ==========================================================
// PDPMRS - Prisma Schema
// Modular monolith: one database, tables grouped by domain
// ==========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------
// Enums
// ----------------------------------------------------------

enum PharmacyLicenseStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum ReservationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum PrescriptionStatus {
  UPLOADED
  PROCESSING
  ANALYZED
  FAILED
  MANUAL_REVIEW
}

enum AdminRole {
  SUPER_ADMIN
  OPERATIONS
  COMPLIANCE
}

enum ActorType {
  PATIENT
  PHARMACY
  ADMIN
  SYSTEM
}

// ----------------------------------------------------------
// Patient Domain
// ----------------------------------------------------------

model Patient {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  fullName          String
  phone             String?
  preferredLanguage String    @default("en")
  emailVerified     Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  verificationTokens EmailVerificationToken[]
  prescriptions       Prescription[]
  reservations         Reservation[]

  @@map("patients")
}

model EmailVerificationToken {
  id         String    @id @default(uuid())
  token      String    @unique
  patientId  String?
  pharmacyId String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  patient  Patient?  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pharmacy Pharmacy? @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ----------------------------------------------------------
// Pharmacy Domain
// ----------------------------------------------------------

model Pharmacy {
  id               String                @id @default(uuid())
  ownerName        String
  businessName     String
  email            String                @unique
  passwordHash     String
  phone            String?
  emailVerified    Boolean               @default(false)

  licenseDocumentUrl String?
  licenseNumber       String?
  licenseStatus        PharmacyLicenseStatus @default(PENDING)
  licenseAiScore        Json?
  licenseReviewedBy     String?
  licenseReviewedAt     DateTime?

  addressLine    String?
  city           String?
  country        String?
  latitude       Float?
  longitude      Float?
  addressVerified Boolean  @default(false)

  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionRenewsAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  verificationTokens EmailVerificationToken[]
  stocks             Stock[]
  reservations       Reservation[]

  @@index([latitude, longitude])
  @@map("pharmacies")
}

// ----------------------------------------------------------
// Medicine Domain
// ----------------------------------------------------------

model Medicine {
  id           String   @id @default(uuid())
  externalId   String?  @unique
  name         String
  genericName  String?
  brandName    String?
  category     String?
  description  String?
  normalizedKey String  @default("")
  source       String   @default("external_api")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  translations MedicineTranslation[]
  stocks       Stock[]
  reservationItems ReservationItem[]

  @@index([name])
  @@index([normalizedKey])
  @@map("medicines")
}

model MedicineTranslation {
  id                 String   @id @default(uuid())
  medicineId         String
  languageCode       String
  translatedName     String
  translatedDescription String?
  createdAt          DateTime @default(now())

  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@unique([medicineId, languageCode])
  @@map("medicine_translations")
}

// ----------------------------------------------------------
// Inventory (Pharmacy Stock) Domain
// ----------------------------------------------------------

model Stock {
  id                String   @id @default(uuid())
  pharmacyId        String
  medicineId        String
  quantity          Int      @default(0)
  price             Decimal? @db.Decimal(10, 2)
  lowStockThreshold Int      @default(5)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  medicine Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, medicineId])
  @@index([quantity])
  @@map("stocks")
}

// ----------------------------------------------------------
// Intelligence Domain (AI outputs)
// ----------------------------------------------------------

model Prescription {
  id                String              @id @default(uuid())
  patientId         String
  fileUrl           String
  status            PrescriptionStatus  @default(UPLOADED)
  ocrText           String?
  extractedMedicines Json?
  score             Json?
  confidence        Float?
  processedAt       DateTime?
  createdAt         DateTime            @default(now())

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@map("prescriptions")
}

// ----------------------------------------------------------
// Reservation Domain
// ----------------------------------------------------------

model Reservation {
  id             String            @id @default(uuid())
  patientId      String
  pharmacyId     String
  prescriptionId String?
  status         ReservationStatus @default(PENDING)
  expiresAt      DateTime
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  pharmacy     Pharmacy      @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])
  items        ReservationItem[]

  @@index([status])
  @@index([expiresAt])
  @@map("reservations")
}

model ReservationItem {
  id            String @id @default(uuid())
  reservationId String
  medicineId    String
  quantity      Int    @default(1)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  medicine    Medicine    @relation(fields: [medicineId], references: [id])

  @@map("reservation_items")
}

// ----------------------------------------------------------
// Administration Domain
// ----------------------------------------------------------

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         AdminRole @default(OPERATIONS)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  @@map("admin_users")
}

model AuditLog {
  id         String    @id @default(uuid())
  actorId    String?
  actorType  ActorType
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
